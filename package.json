{
  "name": "remix3-ui-showcase",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node --watch --import remix/node-tsx server.ts",
    "start": "NODE_ENV=production node --import remix/node-tsx server.ts",
    "test": "NODE_ENV=test node --import remix/node-tsx --test",
    "typecheck": "tsc --noEmit",
    "build": "NODE_ENV=production node --import remix/node-tsx build.ts"
  },
  "dependencies": {
    "remix": "3.0.0-beta.4"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24.3.0"
  }
}